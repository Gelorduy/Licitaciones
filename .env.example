APP_NAME=Licitaciones
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://licitaciones.local:8443

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=licitaciones
DB_USERNAME=licitaciones
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=licitaciones
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://minio:9000

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EXTRACTION_MODEL=gpt-4.1-mini

PINECONE_API_KEY=
PINECONE_INDEX_HOST=

OCR_LANGUAGES=spa+eng
OCR_VISION_PAGES=2
OCR_VISION_MAX_WIDTH=1100
OCR_VISION_QUALITY=60

# Extraction engine: openai or ollama
EXTRACTION_ENGINE=openai
OLLAMA_EXTRACTION_MODEL=qwen2.5:7b-instruct
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_VISION_ENABLED=true
OLLAMA_EXTRACTION_TIMEOUT=300

VITE_APP_NAME="${APP_NAME}"
